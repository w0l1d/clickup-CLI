  "author": "Walid Ahdouf",
  "license": "MIT",
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "axios": "^1.15.1",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "conf": "^10.2.0",
    "js-yaml": "^4.1.0",
    "openapi-types": "^12.1.3",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
