{
  "name": "@w0l1d/clickup-cli",
  "version": "0.2.0",
  "description": "Spec-driven CLI to explore, test, and probe ClickUp's v2 and v3 REST APIs.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "clickup": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "clickup",
    "cli",
    "openapi",
    "api",
    "rest",
    "swagger"
